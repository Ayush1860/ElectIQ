{
  "name": "electiq-election-assistant",
  "version": "1.0.0",
  "description": "ElectIQ – Indian Election Process Assistant powered by Google AI",
  "private": true,
  "scripts": {
    "dev": "npx http-server public -p 3000 -c-1 --cors",
    "build": "node build.js",
    "deploy": "firebase deploy",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "lint": "npx eslint src/ --ext .js",
    "test": "node tests/run.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "ElectIQ Team",
  "license": "MIT"
}
