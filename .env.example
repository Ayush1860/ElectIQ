# ══════════════════════════════════════════════
# ElectIQ — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ══════════════════════════════════════════════

# Firebase Configuration (client-side, safe to expose)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Maps (client-side, restricted by HTTP referrer)
GOOGLE_MAPS_API_KEY=your_maps_api_key

# ── Server-side only (Cloud Functions) ──
# These are set via: firebase functions:config:set gemini.key="YOUR_KEY"
# GEMINI_API_KEY=your_gemini_api_key
# GOOGLE_TRANSLATE_API_KEY=your_translate_api_key
